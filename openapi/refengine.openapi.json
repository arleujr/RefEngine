  "components": {
    "schemas": {
      "ApiRunStatus": {
        "type": "string",
        "enum": [
          "queued",
          "processing",
          "review",
          "published",
          "failed"
        ],
        "title": "ApiRunStatus",
        "description": "Lifecycle of one local input-folder processing run."
      },
      "AttentionItemResponse": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "severity": {
            "type": "string",
            "enum": [
              "warning",
              "error"
            ],
            "title": "Severity"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "field_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field Id"
          },
          "field_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Field Label"
          }
        },
        "type": "object",
        "required": [
          "code",
          "severity",
          "message"
        ],
        "title": "AttentionItemResponse"
      },
      "CandidateResponse": {
        "properties": {
          "values": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Values"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "sources": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sources"
          },
          "methods": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Methods"
          }
        },
        "type": "object",
        "required": [
          "values",
          "score",
          "sources",
          "methods"
        ],
        "title": "CandidateResponse"
      },
      "CatalogFieldResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "repeatable": {
            "type": "boolean",
            "title": "Repeatable"
          },
          "value_type": {
            "type": "string",
            "title": "Value Type"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "repeatable",
          "value_type"
        ],
        "title": "CatalogFieldResponse"
      },
      "FieldDetailResponse": {
        "properties": {
          "field_id": {
            "type": "string",
            "title": "Field Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "repeatable": {
            "type": "boolean",
            "title": "Repeatable"
          },
          "value_type": {
            "type": "string",
            "title": "Value Type"
          },
          "requirement": {
            "type": "string",
            "enum": [
              "required",
              "conditional"
            ],
            "title": "Requirement"
          },
          "selected_values": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Selected Values"
          },
          "resolution_status": {
            "type": "string",
            "title": "Resolution Status"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          },
          "selected_sources": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Selected Sources"
          },
          "alternatives": {
            "items": {
              "$ref": "#/components/schemas/CandidateResponse"
            },
            "type": "array",
            "title": "Alternatives"
          },
          "rule_summary": {
            "type": "string",
            "title": "Rule Summary"
          },
          "rule_details": {
            "type": "string",
            "title": "Rule Details"
          }
        },
        "type": "object",
        "required": [
          "field_id",
          "label",
          "repeatable",
          "value_type",
          "requirement",
          "selected_values",
          "resolution_status",
          "confidence",
          "reason",
          "selected_sources",
          "alternatives",
          "rule_summary",
          "rule_details"
        ],
        "title": "FieldDetailResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "title": "Status",
            "default": "ok"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "local_only": {
            "type": "boolean",
            "title": "Local Only",
            "default": true
          },
          "input_mode": {
            "type": "string",
            "const": "folder",
            "title": "Input Mode",
            "default": "folder"
          },
          "input_directory": {
            "type": "string",
            "title": "Input Directory"
          },
          "api_database": {
            "type": "string",
            "title": "Api Database"
          },
          "frontend_available": {
            "type": "boolean",
            "title": "Frontend Available"
          }
        },
        "type": "object",
        "required": [
          "version",
          "input_directory",
          "api_database",
          "frontend_available"
        ],
        "title": "HealthResponse"
      },
      "InputFileChangeResponse": {
        "properties": {
          "relative_path": {
            "type": "string",
            "title": "Relative Path"
          },
          "change": {
            "type": "string",
            "enum": [
              "added",
              "removed",
              "modified"
            ],
            "title": "Change"
          }
        },
        "type": "object",
        "required": [
          "relative_path",
          "change"
        ],
        "title": "InputFileChangeResponse"
      },
      "InputFileResponse": {
        "properties": {
          "relative_path": {
            "type": "string",
            "title": "Relative Path"
          },
          "source_type": {
            "type": "string",
            "title": "Source Type"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes"
          },
          "sha256": {
            "type": "string",
            "title": "Sha256"
          }
        },
        "type": "object",
        "required": [
          "relative_path",
          "source_type",
          "size_bytes",
          "sha256"
        ],
        "title": "InputFileResponse"
      },
      "InputInventoryResponse": {
        "properties": {
          "input_directory": {
            "type": "string",
            "title": "Input Directory"
          },
          "files": {
            "items": {
              "$ref": "#/components/schemas/InputFileResponse"
            },
            "type": "array",
            "title": "Files"
          },
          "fingerprint": {
            "type": "string",
            "title": "Fingerprint"
          },
          "total_bytes": {
            "type": "integer",
            "title": "Total Bytes"
          },
          "counts": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Counts"
          }
        },
        "type": "object",
        "required": [
          "input_directory",
          "files",
          "fingerprint",
          "total_bytes",
          "counts"
        ],
        "title": "InputInventoryResponse"
      },
      "PublishResponse": {
        "properties": {
          "run": {
            "$ref": "#/components/schemas/RunResponse"
          },
          "references": {
            "type": "integer",
            "title": "References"
          },
          "exports": {
            "additionalProperties": {
              "type": "string"
